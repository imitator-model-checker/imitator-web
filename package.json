{
  "name": "imitator-runner",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "packageManager": "npm@11.17.0",
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "start": "node build/bin/server.js",
    "pm2:start": "pm2 start ecosystem.config.cjs",
    "pm2:reload": "pm2 reload ecosystem.config.cjs",
    "pm2:stop": "pm2 stop ecosystem.config.cjs",
    "pm2:delete": "pm2 delete ecosystem.config.cjs",
    "pm2:logs": "pm2 logs imitator-runner",
    "dev": "npm run build:css && node ace serve --hmr",
    "build": "npm run build:css && node ace build",
    "serve": "node ace serve",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "build:css": "tailwindcss build ./resources/css/tailwind.css -c ./tailwind.config.cjs -o ./public/css/style.css"
  },
  "imports": {
    "#controllers/*": "./app/controllers/*.js",
    "#exceptions/*": "./app/exceptions/*.js",
    "#middleware/*": "./app/middleware/*.js",
    "#start/*": "./start/*.js",
    "#config/*": "./config/*.js",
    "#domain/*": "./app/domain/*.js",
    "#application/*": "./app/application/*.js",
    "#infrastructure/*": "./app/infrastructure/*.js"
  },
  "dependencies": {
    "@adonisjs/core": "^7.3.3",
    "@adonisjs/static": "^2.0.1",
    "@adonisjs/transmit": "^3.0.1",
    "@adonisjs/transmit-client": "^1.1.0",
    "@poppinss/ts-exec": "^1.4.4",
    "axios": "^1.13.2",
    "date-fns": "^4.1.0",
    "edge.js": "^6.5.1",
    "fast-glob": "^3.3.3",
    "node-cron": "^4.2.1",
    "reflect-metadata": "^0.2.2",
    "strip-ansi": "^7.1.2",
    "yauzl": "^3.4.0"
  },
  "devDependencies": {
    "@adonisjs/assembler": "^8.4.0",
    "@adonisjs/eslint-config": "^3.1.0",
    "@adonisjs/prettier-config": "^1.5.0",
    "@adonisjs/tsconfig": "^2.0.0",
    "@types/node": "~25.9.1",
    "@types/yauzl": "^3.4.0",
    "eslint": "^10.4.0",
    "hot-hook": "^1.0.0",
    "pino-pretty": "^13.1.3",
    "prettier": "^3.8.3",
    "tailwindcss": "^1.8.10",
    "typescript": "~6.0.3",
    "youch": "^4.1.1"
  },
  "hotHook": {
    "boundaries": [
      "./app/controllers/**/*.ts",
      "./app/application/**/*.ts",
      "./app/infrastructure/**/*.ts"
    ]
  },
  "prettier": "@adonisjs/prettier-config"
}
